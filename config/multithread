THREADCOUNT=${THREADCOUNT:-$(nproc)}

# This function is passed a list of package.mk paths to be processed.
# Each package.mk is sourced with relevant variables output in JSON format.
json_worker() {
  local packages="$@"
  local pkgpath hierarchy exited

  exit() { exited=1; }

  . config/options ""

  for pkgpath in ${packages}; do
    pkgpath="${pkgpath%%@*}"

    exited=0
    if ! source_package "${pkgpath}/package.mk" &>/dev/null; then
      unset -f exit
      die "$(print_color CLR_ERROR "FAILURE: sourcing package ${pkgpath}/package.mk")"
    fi

    [ ${exited} -eq 1 ] && continue

    [[ ${pkgpath} =~ ^${ROOT}/${PACKAGES}/ ]] && hierarchy="global" || hierarchy="local"

    cat <<EOF
  {
    "name": "${PKG_NAME}",
    "hierarchy": "${hierarchy}",
    "section": "${PKG_SECTION}",
    "bootstrap": "${PKG_DEPENDS_BOOTSTRAP}",
    "init": "${PKG_DEPENDS_INIT}",
    "host": "${PKG_DEPENDS_HOST}",
    "target": "${PKG_DEPENDS_TARGET}"
  },
EOF
  done
}
export -f json_worker

# This function is passed the build instruction for a single job.
# The function will run either "build <package>" or "install <package>".
# ${slot} is the job slot number, ie. 1-8 when THREADCOUNT=8.
# ${job} is the sequence within the total number of ${jobs}.

# 1. Variable initialisation and environment setup
# 2. Parse input args, determine task type and package name
# 3. Load that package's specific config
# 4. Run the core task: build or install
# 5. Handle add-on logic (e.g. installing addons)
# 6. Update global build progress
# 7. Handle success/failure follow-ups
# 8. Return the task result
package_worker() {

  # Four local variables that receive the args passed in from parallel:
  # slot: task slot number (e.g. 1-8 in an 8-thread build).
  # job: this task's index within the total task sequence.
  # jobs: total number of tasks.
  # args: the task's actual arguments, usually "build package_name" or "install package_name".
  local slot=$1 job=$2 jobs=$3 args="$4"
  local task pkgname result status
  local addon istarget isaddon

  # Set and export two env vars so other scripts called from this function (e.g. config/options or the build script) can access the current job ID and total job count.
  export MTJOBID=${slot} MTMAXJOBS=${jobs}

  # Read two words from args into task and pkgname.
  # If args is "build zlib", task becomes "build" and pkgname becomes "zlib".
  read -r task pkgname <<< "${args}"

  # This step prepares all the env vars needed by the upcoming build or install command.
  . config/options "${pkgname}"

  # Synchronisation: ensure only the first package_worker process records parallel's main PID. This PID file may be used to signal parallel later (e.g. to abort the build).
  [ ! -f "${THREAD_CONTROL}/parallel.pid" ] && echo "${PARALLEL_PID}" >"${THREAD_CONTROL}/parallel.pid"

  # Print the upcoming command and its context
  echo "                                                  "
  echo "=================================================="
  echo "## Starting task ##"
  echo "Script path: ${SCRIPTS}/${task}"
  echo "Target package: ${pkgname}"
  echo "Task type (task): ${task}"
  echo "Slot (slot): ${slot}"
  echo "Job index (job): ${job}"
  echo "Total jobs (jobs): ${jobs}"
  echo "Raw task args (args): ${args}"
  echo "--------------------------------------------------"
  echo "Command: ${SCRIPTS}/${task} ${pkgname}"
  echo "=================================================="

  # Run the actual task and capture its result (success/failure).
  ${SCRIPTS}/${task} ${pkgname} 2>&1 && result=0 || result=1



  # Used by the addon-install logic below.
  [[ ${pkgname} =~ :target$ || "${pkgname//:/}" = "${pkgname}" ]] && istarget="yes" || istarget="no"

  [[ "${MTADDONBUILD}" = "yes" && ( "${PKG_IS_ADDON}" = "yes" || "${PKG_IS_ADDON}" = "embedded" ) ]] && isaddon="yes" || isaddon="no"

  # Handle addon installation
  if [ "${isaddon}" = "yes" -a "${istarget}" = "yes" ]; then
    if [ ${result} -eq 0 ]; then
      ${SCRIPTS}/install_addon ${pkgname} 2>&1 && result=0 || result=1
    fi

    if [ ${result} -ne 0 ]; then
      if [ -d "${THREAD_CONTROL}/logs" ]; then
        echo "${PKG_NAME} ${THREAD_CONTROL}/logs/${job}/stdout" >>"${THREAD_CONTROL}/addons.failed"
      else
        echo "${PKG_NAME}" >>"${THREAD_CONTROL}/addons.failed"
      fi
    fi
  fi

  # Update global progress
  (
    # Ensure only one package_worker process updates progress at a time during parallel execution
    flock --exclusive 95
    # Set status to DONE or FAIL based on this task's result, for the upcoming progress-log line
    [ ${result} -eq 0 ] && status="DONE" || status="FAIL"
    # Read the current global progress value
    num=$(< "${THREAD_CONTROL}/progress")
    # Atomicity safeguard for the progress update
    mv "${THREAD_CONTROL}/progress" "${THREAD_CONTROL}/progress.prev"
    # Increment the global progress value
    num=$((num + 1))
    # Final commit of the progress update
    echo ${num} >"${THREAD_CONTROL}/progress"
    # Print the progress line
    printf "[%0*d/%0*d] [%-4s] %-7s %s\n" ${#jobs} ${num} ${#jobs} ${jobs} "${status}" "${task}" "${pkgname}" >&2
  ) 95>"${THREAD_CONTROL}/locks/.progress"

  # Task result follow-up
  if [ ${result} -eq 0 ]; then
    pkg_lock_status "IDLE"
  else
    pkg_lock_status "FAILED" "${pkgname}" "${task}"

    print_color CLR_ERROR "FAILURE: $SCRIPTS/${task} ${pkgname} has failed!\n"

    if [ -d "${THREAD_CONTROL}/logs" ]; then
      cat >&2 <<EOF

The following logs for this failure are available:
  stdout: ${THREAD_CONTROL}/logs/${job}/stdout
  stderr: ${THREAD_CONTROL}/logs/${job}/stderr

EOF
    fi
  fi

  # Return the result
  return ${result}
}
export -f package_worker

start_multithread_build() {
  echo "start_multithread_build"
  #bash -c 'read -n 1 -s -r'

  # Status feedback for single-threaded builds. Key takeaways: result=0 means the build succeeded with no errors; singlethread indicates only a single thread was used (no parallel acceleration).
  local singlethread buildopts result=0

  #THREADCOUNT=1

  # init thread control folder
  echo "Initialising thread control folder"
  echo ${THREAD_CONTROL}
  #bash -c 'read -n 1 -s -r'

  rm -rf "${THREAD_CONTROL}"
  mkdir -p "${THREAD_CONTROL}/locks"
  echo -1 >"${THREAD_CONTROL}/progress.prev"
  echo 0 >"${THREAD_CONTROL}/progress"
  echo 0 >"${THREAD_CONTROL}/status.max"
  touch "${THREAD_CONTROL}/status"

  # Increase file descriptors if building one thread/package
  # During single-threaded builds, temporarily raise the system's file-descriptor limit to avoid build failures caused by too many open files
  [ "${THREADCOUNT}" = "0" ] && ulimit -n ${ULIMITN:-10240}


  # Bootstrap GNU parallel
  # Build and install GNU Parallel, with certain lock mechanisms disabled during the build (MTWITHLOCKS=no)
  MTWITHLOCKS=no $SCRIPTS/build parallel:host 2>&1 || die "Unable to bootstrap parallel package"

  # determine number of available slots for the given THREADCOUNT - optimise logging for single threaded builds
  # Determine whether the configured THREADCOUNT can actually run in parallel on this machine; result is stored in singlethread (yes = effectively single-threaded, no = parallel-capable)
  [ $(seq 1 32 | ${TOOLCHAIN}/bin/parallel --plain --no-notice --max-procs ${THREADCOUNT} echo {%} | sort -n | tail -1) -eq 1 ] && singlethread=yes || singlethread=no

  # create a single log file by default for a single threaded build (or the builder is a masochist)
  # Decide GNU Parallel's logging mode based on actual parallelism (singlethread) and the user's ONELOG setting: single-threaded builds default to merging all logs into one file, parallel builds default to splitting them (or merge if forced), and --group/--ungroup controls readability.
  if [ "${singlethread}" = "yes" -a "${ONELOG,,}" != "no" ] || [ "${ONELOG,,}" = "yes" ]; then
    buildopts+=" --ungroup"
  else
    mkdir -p "${THREAD_CONTROL}/logs"
    #buildopts+=" --group --results ${THREAD_CONTROL}/logs/{#}/"
    buildopts+=" --group"
  fi

  echo "=== Parallel build info ==="
  echo "Effectively single-threaded: $singlethread"
  echo "Requested thread count: $THREADCOUNT"
  echo "Merge logs: $ONELOG"
  echo "Build options: $buildopts"
  echo "===================="
  #bash -c 'read -n 1 -s -r'

  # When building addons, don't halt on error - keep building all packages/addons
  # Based on MTADDONBUILD, append a different --halt option to the GNU Parallel build command, controlling whether a single failed task aborts the rest.
  [ "${MTADDONBUILD}" = "yes" ] && buildopts+=" --halt never" || buildopts+=" --halt now,fail=1"

  # pipefail: return value of a pipeline is the value of the last (rightmost) command to exit with a non-zero status
  # With set -o pipefail, the pipeline's return value becomes the first non-zero exit status in the pipe. If every command exits 0, the pipeline returns 0.
  set -o pipefail

  # Locations of all the .mk files
  # .mk files are simplified/modular Makefile fragments containing build rules, dependencies, and variable definitions. They are the core configs that drive build systems (Make, CMake, etc.).
  echo "PACKAGE_GLOBA: $_CACHE_PACKAGE_GLOBAL"
  echo "PACKAGE_LOCAL: $_CACHE_PACKAGE_LOCAL"

  #bash -c 'read -n 1 -s -r'
  # Read the cache files, process data in parallel, generate the build plan, and save the result to a file. If any step in this long pipeline fails, the error status is captured.
  cat ${_CACHE_PACKAGE_GLOBAL} ${_CACHE_PACKAGE_LOCAL} | \
  # Plan the previously cat'd tasks in batches
    ${TOOLCHAIN}/bin/parallel --plain --no-notice --max-args 30 --halt now,fail=1 json_worker | \
    # Parse metadata: read each package's name, version, dependencies, etc.
    # Dependency analysis: compute a correct build order (topological sort) from the dependency graph.
    # Generate the build plan: build an ordered task list according to that sort.
    # Emit the plan: write it to ${THREAD_CONTROL}/plan.
    # Error handling: if planning fails (e.g. circular dependency), set result=1 to mark the build as failed.
    ${SCRIPTS}/genbuildplan.py --no-reorder --show-wants --build ${@} > "${THREAD_CONTROL}"/plan || result=1

  # Print plan contents (optional)
  echo "=== Generated build plan ==="
  cat "${THREAD_CONTROL}/plan"
  echo "======================"

  # Core execution stage. Once the build plan has been generated successfully (result == 0), invoke package_worker in parallel from the plan file to actually run the builds.
  echo "Build core execution stage"
  #bash -c 'read -n 1 -s -r'

  # Check the previous step's result (the planning step). If it succeeded (result == 0), run the then-branch.
  if [ ${result} -eq 0 ]; then
    # Before starting the long-running parallel build, snapshot the current build environment/config for later traceability, debugging, or restarts.
    save_build_config

    # Read the build plan: take the task list from ${THREAD_CONTROL}/plan.
    # Extract key fields: use awk to grab the first two columns (typically package name and version).
    # Set env vars: define MTBUILDSTART and MTWITHLOCKS for the upcoming parallel tasks.
    # Run tasks in parallel: invoke `parallel` to dispatch package_worker across the task list.
    # Job logging: parallel records each task's start/end time, exit code, etc. into the joblog file.
    # Error handling: if any task fails, the pipeline's exit code is captured and result is set to 1.

    # cat "${THREAD_CONTROL}"/plan: prints the file's contents to stdout as input to the next command.
    # awk '{print $1 " " $2}': extracts the first two columns from each plan line.
    # MTBUILDSTART=$(date +%s) MTWITHLOCKS=yes ${TOOLCHAIN}/bin/parallel ...
    # MTBUILDSTART=$(date +%s): records when each package's build starts.
    # MTWITHLOCKS=yes: enables locking to prevent parallel tasks from racing on shared resources.
    # ${TOOLCHAIN}/bin/parallel: invokes the toolchain's parallel binary to run jobs concurrently.
    # parallel args: --plain --no-notice --max-procs ${THREADCOUNT} --joblog="${THREAD_CONTROL}/joblog" --plus ${buildopts}
    # --plain: disables parallel's special replacement syntax so args are passed verbatim to package_worker.
    # --no-notice: suppresses the version banner and citation prompt.
    # --max-procs ${THREADCOUNT}: cap concurrent package_worker processes at THREADCOUNT.
    # --joblog="${THREAD_CONTROL}/joblog": log file where parallel records job ID, start/end time, exit code, and command for each task. Useful for tracking progress and diagnosing failures.
    # --plus: enables parallel's "plus" mode, which allows extra placeholders like {#} and {##}.
    # ${buildopts}: the dynamically-built options computed earlier (--group, --ungroup, --halt, etc.) controlling logging and failure handling.
    cat "${THREAD_CONTROL}"/plan | awk '{print $1 " " $2}' | \
      MTBUILDSTART=$(date +%s) MTWITHLOCKS=yes ${TOOLCHAIN}/bin/parallel \
        --plain --no-notice --max-procs ${THREADCOUNT} --joblog="${THREAD_CONTROL}/joblog" --plus ${buildopts} \
        package_worker {%} {#} {##} {} || result=1
    rm -f "${THREAD_CONTROL}/parallel.pid"
  fi

  set +o pipefail

  return ${result}
}
